{
  "name": "ss-module-infra",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "app-api",
    "app-service",
    "app-webapp",
    "app-website"
  ],
  "scripts": {
    "dev": "turbo dev",
    "api": "turbo dev --filter=app-api",
    "webapp": "turbo dev --filter=app-webapp",
    "website": "turbo dev --filter=app-website",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"{app-api,app-webapp,app-service,app-website}/src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": "prettier --write"
  },
  "devDependencies": {
    "turbo": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
